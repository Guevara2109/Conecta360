@{
    ViewData["Title"] = "Inicio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* ── ENCABEZADO ── *@
<div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:6px;">
    <div style="font-family:'Permanent Marker',cursive;font-size:2.4rem;color:#1a1a1a;letter-spacing:-1px;line-height:1;">
        Conect360
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;">
        <div style="width:52px;height:52px;border-radius:50%;background:#3a8fd4;border:2px solid #1a1a1a;position:relative;overflow:hidden;">
            <div style="position:absolute;background:#4aaa44;width:26px;height:20px;top:8px;left:8px;border-radius:50% 30% 40% 50%;"></div>
            <div style="position:absolute;background:#4aaa44;width:14px;height:12px;bottom:7px;right:5px;border-radius:40%;"></div>
        </div>
    </div>
</div>
<div style="font-size:13px;color:#888;margin-bottom:10px;font-family:'Caveat',cursive;">
    Tu agenda de contactos personal
</div>
<div style="height:5px;background:#1a1a1a;margin-bottom:20px;"></div>

@* ── ESTADÍSTICAS ── *@
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-bottom:20px;">
    <div style="border:2.5px solid #1a1a1a;background:#fff;padding:14px;text-align:center;">
        <div style="font-size:2.2rem;font-weight:700;color:#1a1a1a;line-height:1;">@ViewBag.TotalContactos</div>
        <div style="font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.5px;margin-top:4px;">Contactos</div>
    </div>
    <div style="border:2.5px solid #1a1a1a;background:#fff;padding:14px;text-align:center;">
        <div style="font-size:2.2rem;font-weight:700;color:#1a1a1a;line-height:1;">@ViewBag.TotalCategorias</div>
        <div style="font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.5px;margin-top:4px;">Categorías</div>
    </div>
    <a href="/Contactos/Create" style="border:2.5px solid #1a1a1a;background:#1a1a1a;color:#fff;padding:14px;text-align:center;text-decoration:none;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;font-family:'Caveat',cursive;transition:background .15s;"
           onmouseover="this.style.background='#4422cc';this.style.borderColor='#4422cc';"
           onmouseout="this.style.background='#1a1a1a';this.style.borderColor='#1a1a1a';">
        <span style="font-size:1.6rem;">+</span>
        <span style="font-size:0.9rem;">Nuevo Contacto</span>
    </a>
</div>

@* ── ACCESOS RÁPIDOS ── *@
<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">
    <a href="/Contactos" class="sketch-box" style="min-height:54px;font-size:1.05rem;text-decoration:none;">
        Ver todos los contactos
    </a>
    <a href="/Contactos/Categorias" class="sketch-box" style="min-height:54px;font-size:1.05rem;text-decoration:none;">
        Organizar por categorías
    </a>
</div>
