@{
    ViewData["Title"] = "Conect360";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* ── ENCABEZADO ── *@
<div class="brand-block">
    <div class="brand-title">Conect360</div>
    <div class="brand-globe">
        <div class="globe-circle">
            <div class="globe-land globe-land-1"></div>
            <div class="globe-land globe-land-2"></div>
        </div>
        <div class="globe-a"></div>
    </div>
</div>
<div class="title-divider"></div>

@* ── BUSCAR ── *@
<div style="margin-bottom:14px">
    <a href="/Contactos" class="sketch-box" style="justify-content:flex-start;font-size:1rem">
        Buscar
    </a>
</div>

@* ── FILA: REGISTRO + GESTIONAR CONTACTOS ── *@
<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">
    <a href="/Contactos/Create" class="sketch-box" style="min-height:54px">
        Registro
    </a>
    <a href="/Contactos" class="sketch-box" style="min-height:54px">
        Gestionar<br />Contactos
    </a>
</div>

@* ── FILA: CATEGORÍAS + TECLADO ── *@
<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">

    @* Columna izquierda *@
    <div style="display:flex;flex-direction:column;gap:10px">
        <a href="/Contactos/Categorias" class="sketch-box" style="min-height:78px;flex-direction:column;align-items:flex-start;justify-content:center;padding-left:14px">
            Organizar<br />Por<br />Categorías
        </a>
        <a href="/Mensajes" class="sketch-box" style="min-height:50px;justify-content:flex-start">
            Mensajes&nbsp;
            <div class="bubble-icon">
                <span><i></i><i></i><i></i></span>
            </div>
        </a>
    </div>

    @* Columna derecha — Teclado *@
    <div>
        <div class="teclado-title">Teclado</div>
        <div class="dial-grid">
            <button class="dial-key" onclick="dialPress('1')">1</button>
            <button class="dial-key" onclick="dialPress('2')">2</button>
            <button class="dial-key" onclick="dialPress('3')">3</button>
            <button class="dial-key" onclick="dialPress('4')">4</button>
            <button class="dial-key" onclick="dialPress('5')">5</button>
            <button class="dial-key" onclick="dialPress('6')">6</button>
            <button class="dial-key" onclick="dialPress('7')">7</button>
            <button class="dial-key" onclick="dialPress('8')">8</button>
            <button class="dial-key" onclick="dialPress('9')">9</button>
            <button class="dial-key" onclick="dialPress('*')">*</button>
            <button class="dial-key" onclick="dialPress('0')">0<br /><small style="font-size:.6rem">+</small></button>
            <button class="dial-key" onclick="dialPress('#')">#</button>
        </div>
        <div class="dial-actions">
            <div></div>
            <div style="display:flex;gap:8px">
                <button class="call-btn call-phone" onclick="alert('Llamar: ' + dialNum)">&#128222;</button>
                <button class="call-btn call-video" onclick="alert('Video...')">&#127909;</button>
            </div>
            <div></div>
        </div>
    </div>

</div>

<script>
    var dialNum = '';
    function dialPress(d) {
        dialNum += d;
    }
</script>
