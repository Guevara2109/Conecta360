@model Conect360.Models.Contacto

@{
    ViewData["Title"] = "Registro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-heading">
    <h2>Registrar Nuevo Contacto</h2>
</div>

<form asp-action="Create" method="post" class="form-sketch">

    <div asp-validation-summary="ModelOnly"
         style="color:#cc2200;font-family:'Caveat',cursive;margin-bottom:12px;border:2px solid #cc2200;padding:8px;background:#fee;display:@(ViewData.ModelState.IsValid ? "none" : "block")">
    </div>

    <div class="row2">
        <div class="fg">
            <label asp-for="Nombre">Nombre *</label>
            <input asp-for="Nombre" placeholder="Ej: Ana" />
            <span asp-validation-for="Nombre" style="color:#cc2200;font-size:12px;"></span>
        </div>
        <div class="fg">
            <label asp-for="Apellido">Apellido *</label>
            <input asp-for="Apellido" placeholder="Ej: López" />
            <span asp-validation-for="Apellido" style="color:#cc2200;font-size:12px;"></span>
        </div>
    </div>

    <div class="row2">
        <div class="fg">
            <label asp-for="Telefono">Teléfono *</label>
            <input asp-for="Telefono" placeholder="+503 XXXX-XXXX" />
            <span asp-validation-for="Telefono" style="color:#cc2200;font-size:12px;"></span>
        </div>
        <div class="fg">
            <label asp-for="Email">Correo Electrónico</label>
            <input asp-for="Email" type="email" placeholder="correo@ejemplo.com" />
            <span asp-validation-for="Email" style="color:#cc2200;font-size:12px;"></span>
        </div>
    </div>

    <div class="fg">
        <label asp-for="Categoria">Categoría</label>
        <select asp-for="Categoria">
            <option value="General">General</option>
            <option value="Familia">Familia</option>
            <option value="Trabajo">Trabajo</option>
            <option value="Amigos">Amigos</option>
            <option value="Favoritos">Favoritos</option>
        </select>
    </div>

    <div class="fg">
        <label asp-for="Notas">Notas</label>
        <textarea asp-for="Notas" placeholder="Información adicional..."></textarea>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-guardar">Guardar Contacto</button>
        <a href="/Contactos" class="btn-cancelar">Cancelar</a>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
