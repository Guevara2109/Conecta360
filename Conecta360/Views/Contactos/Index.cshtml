@model IEnumerable<Conect360.Models.Contacto>

@{
    ViewData["Title"] = "Contactos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-heading">
    <h2>Contactos</h2>
    <a href="/Contactos/Create" class="btn-nuevo">+ Nuevo Contacto</a>
</div>

@* ── BARRA DE BÚSQUEDA Y FILTRO ── *@
<form method="get" action="/Contactos" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;">
    <input class="search-sketch"
           type="text"
           name="buscar"
           value="@ViewBag.Buscar"
           placeholder="Buscar por nombre o teléfono..."
           style="flex:1;min-width:200px;" />
    <select class="search-sketch" name="categoria" style="min-width:180px;">
        <option value="">Todas las categorías</option>
        <option value="General"   @(ViewBag.Categoria == "General"   ? "selected" : "")>General</option>
        <option value="Familia"   @(ViewBag.Categoria == "Familia"   ? "selected" : "")>Familia</option>
        <option value="Trabajo"   @(ViewBag.Categoria == "Trabajo"   ? "selected" : "")>Trabajo</option>
        <option value="Amigos"    @(ViewBag.Categoria == "Amigos"    ? "selected" : "")>Amigos</option>
        <option value="Favoritos" @(ViewBag.Categoria == "Favoritos" ? "selected" : "")>Favoritos</option>
    </select>
    <button type="submit" class="btn-nuevo">Buscar</button>
    @if (!string.IsNullOrEmpty(ViewBag.Buscar as string) || !string.IsNullOrEmpty(ViewBag.Categoria as string))
    {
        <a href="/Contactos" class="btn-cancelar" style="padding:5px 14px;">Limpiar</a>
    }
</form>

@* ── TABLA DE CONTACTOS ── *@
@if (!Model.Any())
{
    <p style="font-family:'Caveat',cursive;color:#888;text-align:center;padding:30px;">
        No se encontraron contactos.
        <a href="/Contactos/Create" style="color:#4422cc;">Registra el primero</a>.
    </p>
}
else
{
    <div style="overflow-x:auto;">
        <table class="table-sketch">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Teléfono</th>
                    <th>Correo</th>
                    <th>Categoría</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Nombre</td>
                        <td>@c.Apellido</td>
                        <td>@c.Telefono</td>
                        <td>@c.Email</td>
                        <td>
                            <span class="badge-cat badge-@c.Categoria.ToLower()">@c.Categoria</span>
                        </td>
                        <td>
                            <a href="/Contactos/Edit/@c.Id" class="act">Editar</a>
                            <form method="post" action="/Contactos/Delete/@c.Id" style="display:inline;"
                                  onsubmit="return confirm('¿Eliminar a @c.Nombre @c.Apellido?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="act del">Borrar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div style="font-family:'Caveat',cursive;font-size:13px;color:#888;margin-top:10px;">
        @Model.Count() contacto(s) encontrado(s)
    </div>
}
