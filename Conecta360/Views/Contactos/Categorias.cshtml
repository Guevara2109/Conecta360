@model IEnumerable<IGrouping<string, Conect360.Models.Contacto>>

@{
    ViewData["Title"] = "Categorías";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-heading">
    <h2>Organizar por Categorías</h2>
    <a href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    </a>
</div>

@if (!Model.Any())
{
    <p style="font-family:'Caveat',cursive;color:#888;text-align:center;padding:20px">
        No hay contactos registrados aún.
    </p>
}
else
{
    foreach (var grupo in Model)
    {
        <div style="border:2px solid #1a1a1a;background:#fff;padding:12px;margin-bottom:12px">
            <div style="font-family:'Permanent Marker',cursive;font-size:1.1rem;color:#111;margin-bottom:8px;border-bottom:2px solid #1a1a1a;padding-bottom:4px">
                @grupo.Key (@grupo.Count())
            </div>
            @foreach (var c in grupo)
            {
                <div style="font-family:'Caveat',cursive;font-size:.95rem;padding:4px 0;border-bottom:1px solid #eee;color:#333">
                    @c.Nombre @c.Apellido &mdash; @c.Telefono
                </div>
            }
        </div>
    }
}
