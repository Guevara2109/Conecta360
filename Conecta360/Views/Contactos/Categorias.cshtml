@model IEnumerable<IGrouping<string, Conect360.Models.Contacto>>

@{
    ViewData["Title"] = "Categorías";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-heading">
    <h2>Organizar por Categorías</h2>
    <a href="/Contactos/Create" class="btn-nuevo">+ Nuevo Contacto</a>
</div>

@* ── FILTRO POR CATEGORÍA ── *@
<form method="get" action="/Contactos/Categorias" style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
    <select class="search-sketch" name="filtro" style="min-width:200px;">
        <option value="">Ver todas las categorías</option>
        <option value="General"   @(ViewBag.Filtro == "General"   ? "selected" : "")>General</option>
        <option value="Familia"   @(ViewBag.Filtro == "Familia"   ? "selected" : "")>Familia</option>
        <option value="Trabajo"   @(ViewBag.Filtro == "Trabajo"   ? "selected" : "")>Trabajo</option>
        <option value="Amigos"    @(ViewBag.Filtro == "Amigos"    ? "selected" : "")>Amigos</option>
        <option value="Favoritos" @(ViewBag.Filtro == "Favoritos" ? "selected" : "")>Favoritos</option>
    </select>
    <button type="submit" class="btn-nuevo">Filtrar</button>
    @if (!string.IsNullOrEmpty(ViewBag.Filtro as string))
    {
        <a href="/Contactos/Categorias" class="btn-cancelar" style="padding:5px 14px;">Ver todas</a>
    }
</form>

@* ── GRUPOS DE CATEGORÍAS ── *@
@if (!Model.Any())
{
    <p style="font-family:'Caveat',cursive;color:#888;text-align:center;padding:30px;">
        No hay contactos registrados aún.
        <a href="/Contactos/Create" style="color:#4422cc;">Registra el primero</a>.
    </p>
}
else
{
    <div class="cats-grid">
        @foreach (var grupo in Model)
        {
            <div class="cat-grupo">
                <div class="cat-titulo">
                    <span>@grupo.Key</span>
                    <span class="badge-cat badge-@grupo.Key.ToLower()">@grupo.Count() contacto(s)</span>
                </div>
                @foreach (var c in grupo)
                {
                    <div class="cat-item">
                        <span>@c.Nombre @c.Apellido</span>
                        <span style="color:#888;">@c.Telefono</span>
                    </div>
                }
            </div>
        }
    </div>
}
