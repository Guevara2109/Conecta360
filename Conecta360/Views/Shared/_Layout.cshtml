<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Conect360</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #e0e0e0;
            font-family: 'Caveat', cursive;
            color: #111;
            min-height: 100vh;
        }

        /* Líneas de cuaderno en el fondo */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: repeating-linear-gradient(
                transparent,
                transparent 27px,
                #b8c8e8 28px
            );
            opacity: 0.35;
            pointer-events: none;
            z-index: 0;
        }

        .page-wrapper {
            position: relative;
            z-index: 1;
            max-width: 480px;
            margin: 20px auto;
            background: #f5f5f0;
            border: 3px solid #1a1a1a;
            border-radius: 2px;
            padding: 18px;
            box-shadow: 4px 4px 0 #999;
            background-image: repeating-linear-gradient(
                transparent,
                transparent 27px,
                #c5d5ee 28px
            );
        }

        /* ── NAV ── */
        .nav-sketch {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 14px;
            padding-bottom: 8px;
            border-bottom: 2px solid #1a1a1a;
        }
        .nav-sketch a {
            border: 2px solid #1a1a1a;
            background: #fff;
            padding: 4px 10px;
            font-size: 0.85rem;
            font-family: 'Caveat', cursive;
            color: #111;
            text-decoration: none;
            transition: background .15s;
        }
        .nav-sketch a:hover { background: #eee8ff; }

        /* ── TÍTULO ── */
        .brand-block {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 4px;
        }
        .brand-title {
            font-family: 'Permanent Marker', cursive;
            font-size: 3rem;
            color: #111;
            letter-spacing: -1px;
            line-height: 1;
        }
        .brand-globe {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .globe-circle {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: #3a8fd4;
            border: 2px solid #1a1a1a;
            position: relative;
            overflow: hidden;
        }
        .globe-land {
            position: absolute;
            background: #4aaa44;
        }
        .globe-land-1 { width: 26px; height: 20px; top: 8px; left: 8px; border-radius: 50% 30% 40% 50%; }
        .globe-land-2 { width: 14px; height: 12px; bottom: 7px; right: 5px; border-radius: 40%; }
        .globe-a {
            font-family: 'Permanent Marker', cursive;
            font-size: 1.6rem;
            color: #4422cc;
            margin-top: 2px;
        }

        .title-divider {
            height: 5px;
            background: #1a1a1a;
            margin: 6px 0 12px;
        }

        /* ── CAJAS GENÉRICAS ── */
        .sketch-box {
            border: 2px solid #1a1a1a;
            background: #fff;
            padding: 10px 14px;
            font-family: 'Caveat', cursive;
            font-size: 1rem;
            color: #111;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            text-decoration: none;
            transition: background .15s;
            cursor: pointer;
            line-height: 1.3;
        }
        .sketch-box:hover { background: #eee8ff; color: #111; }

        /* ── MENSAJES (burbuja) ── */
        .bubble-icon {
            width: 26px;
            height: 26px;
            background: #cc44aa;
            border-radius: 50% 50% 50% 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: 8px;
            flex-shrink: 0;
        }
        .bubble-icon span {
            display: flex;
            gap: 3px;
        }
        .bubble-icon span i {
            width: 4px;
            height: 4px;
            background: #fff;
            border-radius: 50%;
            display: inline-block;
        }

        /* ── TECLADO ── */
        .teclado-title {
            font-family: 'Caveat', cursive;
            font-size: 1.1rem;
            font-weight: 700;
            color: #3355cc;
            text-align: center;
            margin-bottom: 6px;
        }
        .dial-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 4px;
        }
        .dial-key {
            background: transparent;
            border: none;
            font-family: 'Caveat', cursive;
            font-size: 1.3rem;
            font-weight: 700;
            color: #111;
            text-align: center;
            padding: 6px 0;
            cursor: pointer;
            transition: color .15s;
        }
        .dial-key:hover { color: #4422cc; }
        .dial-actions {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            margin-top: 6px;
        }
        .call-btn {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            border: none;
            cursor: pointer;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .call-phone { background: #2db542; color: #fff; }
        .call-video { background: #2b7fd4; color: #fff; }

        /* ── FORMULARIO ── */
        .form-sketch {
            border: 2px solid #1a1a1a;
            background: #fff;
            padding: 16px;
            margin-top: 10px;
        }
        .form-sketch label {
            font-family: 'Caveat', cursive;
            font-size: 0.85rem;
            font-weight: 700;
            color: #444;
            display: block;
            margin-bottom: 2px;
        }
        .form-sketch input,
        .form-sketch select,
        .form-sketch textarea {
            width: 100%;
            border: 2px solid #1a1a1a;
            background: #fff;
            padding: 6px 10px;
            font-family: 'Caveat', cursive;
            font-size: 0.95rem;
            color: #111;
            outline: none;
            transition: border-color .15s;
        }
        .form-sketch input:focus,
        .form-sketch select:focus,
        .form-sketch textarea:focus {
            border-color: #4422cc;
        }
        .form-sketch textarea { min-height: 70px; resize: vertical; }
        .form-sketch .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .form-sketch .fg { margin-bottom: 10px; }

        .btn-guardar {
            width: 100%;
            border: 3px solid #1a1a1a;
            background: #1a1a1a;
            color: #fff;
            font-family: 'Caveat', cursive;
            font-size: 1.05rem;
            font-weight: 700;
            padding: 8px;
            cursor: pointer;
            margin-top: 6px;
            transition: background .15s;
        }
        .btn-guardar:hover { background: #4422cc; border-color: #4422cc; }
        .btn-cancelar {
            width: 100%;
            border: 2px solid #aaa;
            background: #fff;
            color: #666;
            font-family: 'Caveat', cursive;
            font-size: 1rem;
            padding: 7px;
            cursor: pointer;
            margin-top: 6px;
        }
        .btn-cancelar:hover { border-color: #1a1a1a; color: #111; }

        /* ── TABLA ── */
        .table-sketch {
            width: 100%;
            border-collapse: collapse;
            font-family: 'Caveat', cursive;
            font-size: 0.9rem;
        }
        .table-sketch th {
            background: #1a1a1a;
            color: #fff;
            padding: 7px 10px;
            text-align: left;
            font-size: 0.8rem;
        }
        .table-sketch td {
            padding: 6px 10px;
            border-bottom: 1px solid #ccc;
            color: #222;
        }
        .table-sketch tr:hover td { background: #eee8ff; }

        .search-sketch {
            width: 100%;
            border: 2px solid #1a1a1a;
            background: #fff;
            padding: 7px 10px;
            font-family: 'Caveat', cursive;
            font-size: 0.95rem;
            margin-bottom: 10px;
            outline: none;
        }
        .search-sketch:focus { border-color: #4422cc; }

        .btn-nuevo {
            border: 2px solid #1a1a1a;
            background: #1a1a1a;
            color: #fff;
            font-family: 'Caveat', cursive;
            font-size: 0.9rem;
            padding: 5px 14px;
            cursor: pointer;
            margin-bottom: 10px;
            text-decoration: none;
            display: inline-block;
        }
        .btn-nuevo:hover { background: #4422cc; border-color: #4422cc; color: #fff; }

        .page-heading {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 2px solid #1a1a1a;
        }
        .page-heading h2 {
            font-family: 'Permanent Marker', cursive;
            font-size: 1.4rem;
            color: #111;
        }

        /* ── MENSAJES FLASH ── */
        .toast-sketch {
            background: #1a1a1a;
            color: #fff;
            padding: 7px 14px;
            font-family: 'Caveat', cursive;
            font-size: 0.9rem;
            margin-bottom: 10px;
            display: none;
        }
        .toast-sketch.show { display: block; }

        /* ── ACCIÓN BOTONES TABLA ── */
        .act { background: none; border: none; cursor: pointer; font-size: 1rem; padding: 0 3px; }

        footer {
            text-align: center;
            padding: 10px;
            color: #999;
            font-family: 'Caveat', cursive;
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <nav class="nav-sketch">
            <a href="/">Inicio</a>
            <a href="/Contactos/Create">Registro</a>
            <a href="/Contactos">Contactos</a>
            <a href="/Contactos/Categorias">Categorías</a>
            <a href="/Mensajes">Mensajes</a>
        </nav>

        @RenderBody()
    </div>

    <footer>&copy; 2026 Conect360</footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
